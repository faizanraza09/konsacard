# ── shared ─────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
.DS_Store
node_modules/
.env
.env.local

# service account keys (anywhere in the tree)
konsacard-4e4f810a64e3.json

# ── apps/web ──────────────────────────────────────────────────────────────
apps/web/assets/config.js

# Minified JS/CSS bundles, regenerated by `npm run build:assets` (esbuild).
# Source files live in apps/web/assets/*.js + styles.css; dist/ is a build
# artifact, same reasoning as banks/ and restaurants/ below.
apps/web/assets/dist/

# wrangler / cloudflare local state
apps/web/.wrangler/
apps/web/.dev.vars*
!apps/web/.dev.vars.example

# playwright + test outputs
apps/web/.playwright/
apps/web/test-results/
apps/web/playwright-report/

# Generated SEO pages — built at deploy time by scripts/seo/generate_seo_pages.py.
# These are build artifacts, not source. Keep them out of git so:
#   - PRs stay reviewable on data refreshes (~1500 files would diff every time)
#   - Visual edits to bank/restaurant templates take effect without regenerating
#   - No merge conflicts when two devs run the generator on different branches
# Cloudflare Pages runs `npm run build` (which runs the generator) at deploy.
# Locally, run `npm run generate:seo` after pulling to view banks/restaurants.
apps/web/banks/
apps/web/restaurants/

# ── apps/mobile ───────────────────────────────────────────────────────────
# Expo + native build artifacts. Native projects (ios/, android/) are
# regenerated by `npx expo prebuild` and shouldn't be checked in until we
# eject — we want them rebuildable from source.
apps/mobile/.expo/
apps/mobile/dist/
apps/mobile/web-build/
apps/mobile/expo-env.d.ts
apps/mobile/ios/
apps/mobile/android/
apps/mobile/.expo-export-test/

# Local-only or per-developer files
apps/mobile/*.jks
apps/mobile/*.p8
apps/mobile/*.p12
apps/mobile/*.key
apps/mobile/*.mobileprovision
apps/mobile/*.orig.*
