# Cloudflare Pages reads this file and applies the headers to matching
# paths at the edge. Syntax: a route on one line, then header lines
# indented underneath. Empty line ends the block.

# Service worker must never be HTTP-cached, otherwise a deploy can take
# hours (or never) to reach users — the browser keeps serving the cached
# sw.js, which keeps the OLD service worker registered, which keeps
# returning the OLD app shell on Cmd+R. The SW itself caches the app
# shell internally and uses stale-while-revalidate, so the cost of
# re-fetching sw.js on every page load is ~1 KB.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# The same goes for the offers index — it's small (~25 KB) and is what
# tells the rest of the app which city shards to fetch. If it's stale,
# the user sees yesterday's "verified X days ago" chip and yesterday's
# stats banner.
/data/offers-index.json
  Cache-Control: public, max-age=0, must-revalidate

# Raw city shards + restaurant enrichment, lazy-loaded only when a user filters
# or drills in. The index (max-age=0 above) references them as
# offers-<city>.json?v=<content-hash>, so a changed shard gets a new URL and
# busts the cache; the files themselves are safe to cache immutably. Listed
# explicitly (not a /data/offers-*.json glob) so this never overrides the
# max-age=0 on offers-index.json. Add a line here if a new city shard appears.
/data/offers-karachi.json
  Cache-Control: public, max-age=31536000, immutable
/data/offers-lahore.json
  Cache-Control: public, max-age=31536000, immutable
/data/offers-islamabad.json
  Cache-Control: public, max-age=31536000, immutable
/data/offers-restaurants.json
  Cache-Control: public, max-age=31536000, immutable

# Precomputed ranking summary. The loaders fetch it as
# summary.json?v=<summaryVersion>, where summaryVersion is a content hash
# carried by the always-fresh offers-index.json (max-age=0 above). A data
# refresh bumps the hash → a new URL → cache bust, so the file itself is
# safe to cache immutably. This is the small (~64 KB br) payload that powers
# the default first paint instead of the multi-MB raw offer shards.
/data/summary.json
  Cache-Control: public, max-age=31536000, immutable

# Manifest changes rarely but when it does (icon swap, theme color),
# we want the new copy picked up promptly on next visit.
/manifest.webmanifest
  Cache-Control: public, max-age=300, must-revalidate

# Versioned bundles. The build script stamps ?v=<content-hash> into every
# <script> and <link> tag in HTML; any code change produces a new hash and
# therefore a new URL, so we can safely tell the browser to never re-check
# until the URL changes. immutable means even a forced reload won't hit
# origin for these. Saves a conditional GET per file per page load.
#
# IMPORTANT: this only takes effect if Cloudflare's zone-level Browser
# Cache TTL is set to "Respect Existing Headers" (Dashboard → Caching →
# Configuration). Otherwise Cloudflare overrides these.
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable
/assets/dist/*.js
  Cache-Control: public, max-age=31536000, immutable
/assets/dist/*.css
  Cache-Control: public, max-age=31536000, immutable
# Source maps are tiny and only fetched by DevTools / Sentry; same long cache
# is fine since the file name changes (?v=hash) when sources change.
/assets/dist/*.js.map
  Cache-Control: public, max-age=31536000, immutable
/assets/dist/*.css.map
  Cache-Control: public, max-age=31536000, immutable
