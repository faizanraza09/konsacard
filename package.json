{
  "name": "konsacard",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the KonsaCard web + mobile apps. Each app under apps/ keeps its own lockfile and node_modules; npm workspaces will be wired up in Phase 2 when packages/algorithms/ is introduced.",
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:web:static": "cd apps/web && npm run dev:static",
    "dev:mobile": "cd apps/mobile && npm start",
    "test:web": "cd apps/web && npm test",
    "test:mobile": "cd apps/mobile && npx jest",
    "build:web": "cd apps/web && npm run build",
    "build:web:deploy": "cd apps/web && npm run build:deploy",
    "refresh:offers": "cd apps/web && npm run refresh:offers",
    "refresh:requirements": "cd apps/web && npm run refresh:requirements",
    "refresh:all": "cd apps/web && npm run refresh:all"
  }
}
